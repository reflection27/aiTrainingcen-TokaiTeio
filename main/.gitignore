# 只跟踪main文件夹内的内容
# 注意：不要使用 /* 来忽略所有文件，因为这会导致 main/ 文件夹也被忽略

# 环境变量文件（包含敏感信息）
.env

# 配置文件（包含敏感信息）
ai_agent_config.json

# Python虚拟环境
venv/
env/
ENV/
.venv/

# 记忆系统数据库文件
*.db
memory_lake.json

# 聊天日志
chat_logs/

# 数据目录
data/

# 恢复文件
recovered_files/

# 临时文件
temp/
temp_*.py
temp_*.txt
*.backup

# 截图文件
temp_screenshots/

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# IDE配置
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# 压缩包
*.zip
*.tar.gz

# 系统文件
.DS_Store
Thumbs.db

# 日志文件
logs/
*.log

# 插件和预训练模型
main/plugins/x/
plugins/RealtimeSTT-master/

# 角色模型权重（通过 setup.bat 下载）
character/*/weights/*
!character/*/weights/.gitkeep

# Godot 可执行文件（体积过大，超过 GitHub 100MB 限制）
plugins/godot/Godot_v4.6.2-stable_win64.exe/

# 冗余文件夹及其下的所有内容
冗余/

